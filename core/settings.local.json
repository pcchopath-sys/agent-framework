{
  "permissions": {
    "allow": [
      "Bash(ollama list *)",
      "Bash(ollama pull *)",
      "Skill(update-config)",
      "Bash(mkdir -p ~/claude-local-ui)",
      "Bash(npm init *)",
      "Bash(npm install *)",
      "Bash(chmod +x ~/Desktop/MyCustomAI.command)",
      "Bash(ls *)",
      "Bash(killall node *)",
      "WebFetch(domain:www.electronjs.org)",
      "Bash(npm run *)",
      "Bash(npx electron-packager *)",
      "Bash(sudo chown *)",
      "Bash(mkdir -p ~/claude-local-ui/.claude/plugins)",
      "Bash(touch ~/claude-local-ui/.claude/plugins/figma_installed.lock)",
      "WebFetch(domain:github.com)",
      "Bash(npx tailwindcss *)",
      "Bash(npx playwright *)",
      "Bash(./node_modules/.bin/tailwindcss init *)",
      "Bash(tailwindcss init *)",
      "Bash(npm rebuild *)",
      "Bash(chmod +x *)"
    ]
  },
  "model": "qwen-3.6-plus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; if [[ \"$f\" == *.{js,ts,jsx,tsx,json,css,md} ]]; then npx prettier --write \"$f\" 2>/dev/null || true; fi; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
