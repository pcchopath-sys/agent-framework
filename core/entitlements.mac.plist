<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://apple.com">
<plist version="1.0">
  <dict>
    <!-- Izinkan Just-In-Time (JIT) compilation, wajib untuk engine V8 (Chrome/Node) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Izinkan pemuatan library yang tidak ditandatangani oleh Apple (untuk native modules) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Izinkan aplikasi memuat library dari luar bundle (untuk debugging/plugin) -->
    <key>com.apple.security.cs.allow-dyld-shared-cache</key>
    <true/>

    <!-- Opsi Tambahan (Hanya aktifkan jika aplikasi Anda memerlukannya): -->
