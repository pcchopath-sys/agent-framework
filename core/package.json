{
  "name": "gemma-intel",
  "version": "1.0.0",
  "description": "Symphony of Brains - Intel Mac Optimized",
  "main": "main.js",
  "scripts": {
    "start": "node main.js",
    "desktop": "electron .",
    "build": "CSC_LINK=identities electron-builder build --mac --x64",
    "build:fast": "electron-builder build --mac --x64 -c.mac.identity=null",
    "package": "electron-packager . Gemma-Intel --platform=darwin --arch=x64 --out=dist --overwrite",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.15.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-packager": "^17.1.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.pcchopath.gemma-intel",
    "files": [
      "**/*",
      "!dist{,/**/*}",
      "!dist-*{,/**/*}",
      "!Openrouter{,/**/*}",
      "!node_modules copy{,/**/*}",
      "!chats.json",
      "!settings.local.json",
      "!CLAUDE.md",
      "!SKILL.md",
      "!screenshot-capture.js",
      "!pcchopath.code-workspace",
      "!main.js`"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "target": ["dmg"]
    }
  }
}
